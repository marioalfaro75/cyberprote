# Stage 1: Build
FROM golang:1.23-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /csf-api ./cmd/api/

# Stage 2: Final
FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /csf-api /csf-api

EXPOSE 8080

ENTRYPOINT ["/csf-api"]
